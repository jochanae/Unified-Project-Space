# ──────────────────────────────────────────────────────────────
# SanctumIQ — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored. Never commit real keys.
# ──────────────────────────────────────────────────────────────

# Supabase (anon/publishable — safe for client-side use)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Supabase service role (server-side ONLY — never expose to browser)
# Used by supabase/functions edge functions and server-fn admin operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
